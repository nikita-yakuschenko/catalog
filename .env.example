# Database
POSTGRES_USER=avgst
POSTGRES_PASSWORD=avgst
POSTGRES_DB=avgst_catalog
DATABASE_URL=postgresql+asyncpg://avgst:avgst@localhost:5436/avgst_catalog

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:3000
STORAGE_DIR=/app/storage
OUTPUT_DIR=/app/output
TEMPLATES_DIR=/app/templates

# Tilda sources
TILDA_API_BASE=https://store.tildaapi.com/api/getproductslist/
TILDA_MODULAR_STOREPARTUID=211557090161
TILDA_MODULAR_RECID=1128265271
TILDA_PANEL_STOREPARTUID=410948745601
TILDA_PANEL_RECID=1128270966

# Client
NEXT_PUBLIC_API_URL=http://localhost:8000

# Render
PDF_RENDERER=chromium
PRINCE_BIN=
MAX_ASSET_SIZE_MB=25
HTTP_TIMEOUT_SEC=30
# Min width and height (px) for synced images; smaller files are dropped (Tilda page junk)
MIN_ASSET_EDGE_PX=128
# Max images synced per project (API + page slider)
MAX_SYNC_ASSETS_PER_PROJECT=24

# Bitrix24 webhook (optional, header X-Bitrix-Webhook-Secret)
BITRIX_WEBHOOK_SECRET=
