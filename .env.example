# Database
POSTGRES_USER=avgst
POSTGRES_PASSWORD=avgst
POSTGRES_DB=avgst_catalog
DATABASE_URL=postgresql+asyncpg://avgst:avgst@localhost:5436/avgst_catalog

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:3000
STORAGE_DIR=/app/storage
OUTPUT_DIR=/app/output
TEMPLATES_DIR=/app/templates

# Tilda sources
TILDA_API_BASE=https://store.tildaapi.com/api/getproductslist/
TILDA_MODULAR_STOREPARTUID=211557090161
TILDA_MODULAR_RECID=1128265271
TILDA_PANEL_STOREPARTUID=410948745601
TILDA_PANEL_RECID=1128270966

# Client — leave empty for same-origin via Next proxy (local + cloudflared tunnel).
# Set only if the browser must call the API host directly (e.g. Docker UI → host:8000).
NEXT_PUBLIC_API_URL=
# Optional: backend target for Next.js rewrites (server-side only)
BACKEND_URL=http://127.0.0.1:8000

# Render
PDF_RENDERER=chromium
PRINCE_BIN=
MAX_ASSET_SIZE_MB=25
HTTP_TIMEOUT_SEC=30
# Min width and height (px) for synced images; smaller files are dropped (Tilda page junk)
MIN_ASSET_EDGE_PX=128
# Max images synced per project (API + page slider)
MAX_SYNC_ASSETS_PER_PROJECT=24

# Bitrix24 — исходящий вебхук на нас (опционально, заголовок X-Bitrix-Webhook-Secret)
BITRIX_WEBHOOK_SECRET=
# Bitrix24 — входящий REST вебхук (CRM + user + disk), со слэшем в конце
BITRIX_REST_WEBHOOK_URL=
# Опционально: код UF исходного файла / UF результата / ID папки Диска для КП
BITRIX_SOURCE_FILE_FIELD=
BITRIX_RESULT_FILE_FIELD=
BITRIX_KP_FOLDER_ID=
# SPA entityTypeId «База проектов» (поле parentId{N} на элементе КП)
BITRIX_PROJECT_ENTITY_TYPE_ID=1212
# STATUS_ID стадии «КП Готово»
BITRIX_READY_STAGE_ID=DT1240_163:CLIENT
